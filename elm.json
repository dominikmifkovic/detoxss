{
    "type": "package",
    "name": "dominikmifkovic/detoxss",
    "summary": "XSS detection using AST traversal and sanitization helpers for Elm",
    "license": "MIT",
    "version": "1.0.0",
    "exposed-modules": [
        "DetoXSS.Ast",
        "DetoXSS.Sanitize",
        "DetoXSS.Attributes",
        "DetoXSS.Whitelist",
        "DetoXSS.Port",
        "DetoXSS.Validate",
        "DetoXSS.Core",
        "DetoXSS.ExprParser"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/json": "1.0.0 <= v < 2.0.0",
        "elm/parser": "1.0.0 <= v < 2.0.0",
        "elm/regex": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {}
}